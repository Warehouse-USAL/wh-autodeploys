# Infra-layer secrets for docker-compose (copy to .env, which is gitignored).
# These are the ONLY secrets this repo touches.

# Org that owns the repos/images
GH_OWNER=Warehouse-USAL

# A PAT used by the runner containers to self-register AND to pull private
# images from GHCR. Classic token scopes: repo + read:packages.
GH_PAT=ghp_xxx

# Optional
# GHCR_USER=your-username     # defaults to GH_OWNER
# RUNNER_NAME_PREFIX=wh       # runner names become <prefix>-backend / <prefix>-dashboard / <prefix>-webapp
# RUNNER_LABELS=prod          # job targeting label
# RECONCILE_INTERVAL=300      # seconds between reconcile passes
# WH_ROOT=/opt/wh

# ---------------------------------------------------------------------------
# App runtime config does NOT live here. Each app repo ships its own
# .env.example — copy it to .env in the app's clone under $WH_ROOT and fill in:
#   /opt/wh/wh-backend/.env          (Mongo URI, JWT secret, Mongo root creds, ...)
#   /opt/wh/Dashboard/.env           (frontends call the backend at root; no
#   /opt/wh/smarthouse_webapp/.env    BACKEND_URL needed — both serve under a
#                                      path prefix and hit /auth, /products, ...)
