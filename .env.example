# Infra-layer environment for scripts/init.sh + scripts/bootstrap.sh.
# Copy to a local .env and fill in, or export these before running.
# These are the ONLY secrets this repo touches.

# GHCR pull credentials (a PAT with read:packages)
GHCR_USER=your-github-username
GHCR_PAT=ghp_xxx

# Self-hosted runner registration tokens (short-lived; mint fresh per box from
# each repo's Settings -> Actions -> Runners -> New self-hosted runner).
# Leave RUNNER_TOKEN_DASHBOARD unset to set up the backend only.
RUNNER_TOKEN_BACKEND=xxx
RUNNER_TOKEN_DASHBOARD=xxx

# Optional: override the install root (default /opt/wh)
# WH_ROOT=/opt/wh

# ---------------------------------------------------------------------------
# App runtime config does NOT live here. Each app repo ships its own
# .env.example — copy it to .env in the app's clone and fill it in:
#   /opt/wh/wh-backend/.env   (from wh-backend's .env.example)
#   /opt/wh/Dashboard/.env    (from Dashboard's .env.example)
