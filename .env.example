# Bootstrap-time environment (passed to scripts/bootstrap.sh, NOT committed).
# Copy to a local .env and fill in, or export these before running bootstrap.

# GHCR pull credentials (a PAT with read:packages)
GHCR_USER=your-github-username
GHCR_PAT=ghp_xxx

# Self-hosted runner registration tokens (short-lived; mint fresh per box from
# each repo's Settings -> Actions -> Runners -> New self-hosted runner)
RUNNER_TOKEN_BACKEND=xxx
RUNNER_TOKEN_DASHBOARD=xxx

# Optional: override the install root (default /opt/wh)
# WH_ROOT=/opt/wh

# ---------------------------------------------------------------------------
# Per-app runtime secrets do NOT live here. They go in:
#   /opt/wh/wh-backend/.env   ->  SPRING_DATA_MONGODB_URI, JWT_SECRET,
#                                 MONGO_ROOT_USER, MONGO_ROOT_PASSWORD, ...
#   /opt/wh/Dashboard/.env    ->  BACKEND_URL (defaults to /api)
